enum Role {
  Admin
  Student
  Alumni
  AlumniMentor
}

enum Degree {
  D3
  D4
  S1
  S2
  S3
}

model User {
  id         Int       @id @default(autoincrement())
  userName   String    @unique @db.VarChar(30)
  fullName   String    @db.VarChar(100)
  email      String    @unique @db.VarChar(100)
  password   String    @db.VarChar(500)
  role       Role      @default(Student)
  field      String?   @db.VarChar(50)
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  schools    UserSchool[]
  works      UserWork[]
}

model UserSchool {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  
  nim          String?   @db.VarChar(15) // Nullable untuk Alumni
  campusName   String    @db.VarChar(50)
  major        String    @db.VarChar(50)
  degree       Degree    // Enum Degree (D3, D4, S1, dst)
  
  intakeDate   DateTime  @db.Date
  graduateDate Int?      // Nullable jika belum lulus
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
}

model UserWork {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  
  workPlace  String    @db.VarChar(50)
  fromYear   Int
  toYear     Int?      // Nullable jika masih bekerja di sana
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
}