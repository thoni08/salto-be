
model User {
  id          Int          @id @default(autoincrement())
  userName    String       @unique @db.VarChar(30)
  fullName    String       @db.VarChar(100)
  email       String       @unique @db.VarChar(100)
  password    String       @db.VarChar(500)
  isAdmin     Boolean      @default(false)
  
  // Relasi ke tabel lain
  studentProfile StudentUser?
  alumniProfile  AlumniUser?
}

model StudentUser {
  id      Int    @id @default(autoincrement())
  userId  Int    @unique
  nim     String @db.VarChar(15)
  major   String @db.VarChar(50)
  batch   Int
  campus  String @db.VarChar(50)

  // Menghubungkan userId ke id di model User
  user    User   @relation(fields: [userId], references: [id])
}

model AlumniUser {
  id              Int     @id @default(autoincrement())
  userId          Int     @unique
  field           String  @db.VarChar(50)
  campusOrigin    String  @db.VarChar(50)
  graduateYear    Int
  major           String  @db.VarChar(50)
  currentWorkPlace String @db.VarChar(100)
  isPhD           Boolean @default(false)
  isMentor        Boolean @default(false)

  // Menghubungkan userId ke id di model User
  user            User    @relation(fields: [userId], references: [id])
}